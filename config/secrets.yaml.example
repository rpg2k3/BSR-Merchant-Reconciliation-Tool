# BSR Reconciliation Tool — secrets template.
#
# Copy this file to `config/secrets.yaml` and fill in real values:
#
#     cp config/secrets.yaml.example config/secrets.yaml
#
# `config/secrets.yaml` is git-ignored — NEVER commit real secrets. This
# `.example` file (with empty placeholders) is the only secrets file in git.
#
# `claude_api_key` is populated when an Anthropic API key is added. Until then
# the deferred PDF parser (parsers/pdf_via_claude_api.py) raises
# NotImplementedError and this value stays empty. See docs/pdf_parser_plan.md.

claude_api_key: ""
